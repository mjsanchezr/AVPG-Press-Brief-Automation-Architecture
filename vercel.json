{
  "version": 2,
  "functions": {
    "apps/automation/src/api/execute-brief.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "builds": [
    {
      "src": "apps/automation/src/api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "apps/dashboard/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/automation/src/api/$1.ts"
    },
    {
      "source": "/(.*)",
      "destination": "apps/dashboard/$1"
    }
  ]
}
