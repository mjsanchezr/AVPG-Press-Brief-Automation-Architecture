{
  "version": 2,
  "functions": {
    "apps/automation/src/api/*.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/automation/src/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/dashboard/$1"
    }
  ]
}
